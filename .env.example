MONGO_URI=mongodb://mongo:27017/tasksdb
BACKEND_PORT=4000
FRONTEND_PORT=4200

# IANA timezone the backend container runs in. Work/sleep-schedule times in Settings are plain
# HH:MM strings with no timezone of their own, so the planner interprets them as this zone's local
# clock time - it must match your real timezone or scheduled tasks will land at the wrong hours.
# Defaults to UTC if unset. Find yours at https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Google Calendar OAuth (read-only sync for the Planner feature) - from a Google Cloud Console
# OAuth client. GOOGLE_REDIRECT_URI must exactly match the redirect URI whitelisted there and
# point at the backend's /api/calendar/oauth2callback route.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth2callback
FRONTEND_URL=http://localhost:4200
